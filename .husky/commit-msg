#!/bin/sh

commit_msg=$(cat "$1")

# Allow merge commits and revert commits through without validation
case "$commit_msg" in
  Merge*|Revert*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|test|chore|ci|build|perf)(\(([a-z]([a-z-]*[a-z])?)\))?: \[KAN-[0-9]+\] .+'

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "ERROR: Invalid commit message format."
  echo ""
  echo "  Expected: <type>(<scope>)?: [KAN-<id>] <subject>"
  echo "  Examples: feat(backend): [KAN-10] implement RBAC middleware"
  echo "            ci: [KAN-10] add GitHub Actions workflow"
  echo ""
  echo "  Types:  feat | fix | docs | style | refactor | test | chore | ci | build | perf"
  echo "  Scope:  optional, lowercase letters and hyphens (for example: frontend, back-end, ci-cd)"
  echo ""
  echo "  Your message: $commit_msg"
  echo ""
  exit 1
fi
