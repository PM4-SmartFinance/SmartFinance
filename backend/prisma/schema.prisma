generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- FACT TABLE ---

model FactSpending {
  id     String  @id @default(uuid())
  amount Decimal @db.Decimal(12, 2)

  userId String
  user   DimUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  merchantId String
  merchant   DimMerchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  dateId Int
  date   DimDate @relation(fields: [dateId], references: [id])

  @@index([userId])
  @@index([merchantId])
  @@index([dateId])
}

// --- MAPPING BRIDGE ---

model UserMerchantMapping {
  userId String
  user   DimUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  merchantId String
  merchant   DimMerchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  categoryId String
  category   DimCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([userId, merchantId])
  @@index([categoryId])
}

// --- DIMENSION TABLES ---

model DimMerchant {
  id   String @id @default(uuid())
  name String

  spendings FactSpending[]
  mappings  UserMerchantMapping[]
}

model DimCategory {
  id           String  @id @default(uuid())
  categoryName String
  budgetLimit  Decimal @db.Decimal(12, 2)

  userId String
  user   DimUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  mappings UserMerchantMapping[]

  @@unique([userId, categoryName])
  @@index([userId])
}

model DimUser {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String

  spendings  FactSpending[]
  mappings   UserMerchantMapping[]
  categories DimCategory[]
}

model DimDate {
  id        Int    @id // YYYYMMDD
  dayOfWeek String
  month     Int
  year      Int

  spendings FactSpending[]
}
