# ─── Domain & TLS ──────────────────────────────────────────────────────────────
# Your public domain (must point to this server's IP for Let's Encrypt to work).
DOMAIN=smartfinance.example.com

# Email used for Let's Encrypt certificate registration and expiry notices.
ACME_EMAIL=admin@example.com

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=smartfinance
POSTGRES_USER=smartfinance
POSTGRES_PASSWORD=changeme_use_a_strong_random_password

# Full Prisma-compatible connection URL (used by the backend at runtime and for migrations).
DATABASE_URL=postgresql://smartfinance:changeme_use_a_strong_random_password@postgres:5432/smartfinance

# ─── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Secret for signing httpOnly session cookies. Generate: openssl rand -hex 64
SESSION_SECRET=changeme_generate_with_openssl_rand_hex_64

BCRYPT_ROUNDS=12

# ─── Docker Compose ────────────────────────────────────────────────────────────
# GitHub repository in lowercase owner/repo format (used to pull GHCR images).
# Example: pm4-smartfinance/smartfinance
GITHUB_REPOSITORY=your-org/smartfinance
